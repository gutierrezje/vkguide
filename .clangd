CompileFlags:
  # Use the compilation database generated by CMake presets.
  CompilationDatabase: build
  # clangd may invoke the compiler for queries; MSVC's cl.exe errors out if
  # /Fo (object output) is present during some of those invocations.
  Remove:
    - "/Fo*"
    - "/Fd*"
    - "/FS"
  # Fallback flags used when no compile_commands.json is available.
  Add:
    - -std=c++23
    - -isystem
    - C:/VulkanSDK/1.4.341.1/Include
    - -Ithird_party/vma

